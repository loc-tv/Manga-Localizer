# =========================================================
# Manga Localizer - .gitignore
# =========================================================

# =========================================================
# Python
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# =========================================================
# Virtual Environment
# =========================================================
venv/
.venv/
env/

# =========================================================
# Environment Variables
# =========================================================
.env
.env.local

# =========================================================
# Build / Distribution
# =========================================================
build/
dist/
*.egg-info/
*.spec

# PyInstaller
*.manifest
*.exe

# =========================================================
# Logs
# =========================================================
logs/
*.log

# =========================================================
# Temporary Files
# =========================================================
temp/
tmp/
.cache/

# =========================================================
# Database
# =========================================================
*.db
*.sqlite
*.sqlite3

# =========================================================
# User Projects
# =========================================================
projects/

# =========================================================
# Generated Processing Outputs
# =========================================================
generated/
preview/
rendered/
cleaned/
masks/
exports/
thumbnails/

# =========================================================
# AI Models / Weights
# =========================================================
models/
checkpoints/
weights/

*.pth
*.pt
*.onnx
*.bin
*.safetensors

# =========================================================
# OCR / Translation Cache
# =========================================================
ocr_cache/
translation_cache/

# =========================================================
# Testing / Coverage
# =========================================================
.pytest_cache/
.coverage
htmlcov/

# =========================================================
# Type Checking / Lint
# =========================================================
.mypy_cache/
.ruff_cache/

# =========================================================
# Jupyter
# =========================================================
.ipynb_checkpoints/

# =========================================================
# IDE
# =========================================================
.vscode/
.idea/

# =========================================================
# OS Files
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# Qt / PySide Generated
# =========================================================
*.qmlc
*.jsc

# =========================================================
# App Runtime Files
# =========================================================
session.json
runtime_state.json

# =========================================================
# Keep Important Assets
# =========================================================
!assets/fonts/
!assets/icons/
!assets/themes/

# =========================================================
# Keep Config Templates
# =========================================================
!config/default.yaml
!config/translation.yaml
!config/typography.yaml

# =========================================================
# Keep Documentation
# =========================================================
!README.md
!requirements.txt
!pyproject.toml